# Jira OAuth 2.0 (3LO)
# Créez votre app sur: https://developer.atlassian.com/console/myapps/
# Callback URL prod: https://votre-domaine.vercel.app/api/auth/jira/callback
# Scopes requis: read:jira-work  read:jira-user  offline_access  read:account
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Vercel Blob Storage
# Obtenez votre token depuis: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=

# Web Push Notifications (optionnel)
# Générez vos clés VAPID avec: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:votre@email.com
