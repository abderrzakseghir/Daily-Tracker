# Vercel Blob Storage
# Obtenez votre token depuis: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=

# Web Push Notifications (optionnel)
# Générez vos clés VAPID avec: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:votre@email.com
